{
  "routes": [
    {
      "src": "/sitemap.xml",
      "headers": { "Content-Type": "application/xml" }
    },
    {
      "src": "/robots.txt",
      "headers": { "Content-Type": "text/plain" }
    },
    {
      "src": "/index.html",
      "status": 301,
      "headers": { "Location": "/" }
    }
  ],
  "redirects": [
    {
      "source": "/404",
      "destination": "/404-zh-CN.html",
      "permanent": false
    }
  ]
}